{"data":{"sql":"select * from (-- fct_feature_usage: Feature usage fact table\r\n-- Grain: one row per daily feature usage log\r\n\r\nwith usage as (\r\n    select * from \"ravenstack\".\"main_staging\".\"stg_feature_usage\"\r\n),\r\n\r\nsubscriptions as (\r\n    select subscription_id, subscription_key, account_key\r\n    from \"ravenstack\".\"main_marts\".\"fct_subscriptions\"\r\n)\r\n\r\nselect\r\n    md5(cast(coalesce(cast(u.usage_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT))  as usage_key,\r\n    u.usage_id,\r\n\r\n    -- Foreign keys\r\n    s.subscription_key,\r\n    s.account_key,\r\n\r\n    -- Dimensions\r\n    u.usage_date,\r\n    u.feature_name,\r\n    u.is_beta_feature,\r\n\r\n    -- Measures\r\n    u.usage_count,\r\n    u.usage_duration_secs,\r\n    round(u.usage_duration_secs / 60.0, 2)            as usage_duration_mins,\r\n    u.error_count,\r\n    case when u.error_count > 0 then true else false end as had_errors\r\n\r\nfrom usage u\r\nleft join subscriptions s on u.subscription_id = s.subscription_id\n) limit 1000"},"info":{"category":"","code":"E017","extra":{},"invocation_id":"019cede4-3a79-7840-a0b2-8e16bcc1918a","level":"debug","msg":"-- created_at: 2026-03-14T19:48:05.335579100+00:00\n-- finished_at: 2026-03-14T19:48:05.346811200+00:00\n-- elapsed: 11ms\n-- outcome: success\n-- dialect: duckdb\n-- node_id: not available\n-- query_id: not available\n-- desc: dbt run query\nselect * from (-- fct_feature_usage: Feature usage fact table\r\n-- Grain: one row per daily feature usage log\r\n\r\nwith usage as (\r\n    select * from \"ravenstack\".\"main_staging\".\"stg_feature_usage\"\r\n),\r\n\r\nsubscriptions as (\r\n    select subscription_id, subscription_key, account_key\r\n    from \"ravenstack\".\"main_marts\".\"fct_subscriptions\"\r\n)\r\n\r\nselect\r\n    md5(cast(coalesce(cast(u.usage_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT))  as usage_key,\r\n    u.usage_id,\r\n\r\n    -- Foreign keys\r\n    s.subscription_key,\r\n    s.account_key,\r\n\r\n    -- Dimensions\r\n    u.usage_date,\r\n    u.feature_name,\r\n    u.is_beta_feature,\r\n\r\n    -- Measures\r\n    u.usage_count,\r\n    u.usage_duration_secs,\r\n    round(u.usage_duration_secs / 60.0, 2)            as usage_duration_mins,\r\n    u.error_count,\r\n    case when u.error_count > 0 then true else false end as had_errors\r\n\r\nfrom usage u\r\nleft join subscriptions s on u.subscription_id = s.subscription_id\n) limit 1000;","name":"SQLQuery","pid":31336,"thread":"tokio-runtime-worker","ts":"2026-03-14T19:48:05.346827Z"}}
