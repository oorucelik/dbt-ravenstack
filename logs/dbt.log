    c.feedback_text,

    -- Flags
    c.had_preceding_upgrade,
    c.had_preceding_downgrade,
    c.is_reactivation,

    -- Measures
    c.refund_amount_usd,
    case when c.refund_amount_usd > 0 then true else false end as had_refund

from churn c
left join accounts a on c.account_id = a.account_id
    );
  
  
